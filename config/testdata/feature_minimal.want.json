{
  "listen": "0.0.0.0:8443",
  "llm_fail_mode": "closed",
  "policy": {
    "approvers": {
      "ops": {
        "body": {
          "Channel": "#agent-ops",
          "Credential": "",
          "Timeout": 600,
          "RequireApprovers": 0,
          "Interactive": false
        },
        "type": "human_approver"
      }
    },
    "credentials": {
      "github-pat": {
        "body": {
          "IdempotencyKey": false
        },
        "type": "bearer_token"
      }
    },
    "endpoints": {
      "github": {
        "body": {
          "Hosts": [
            "api.github.com",
            "github.com"
          ],
          "Credential": "github-pat"
        },
        "family": "http",
        "type": "https"
      }
    },
    "profiles": {
      "default": {
        "endpoints": [
          "github"
        ]
      }
    },
    "rules": {
      "github-reads": {
        "body": {
          "name": "github-reads",
          "family": "http",
          "endpoints": [
            "github"
          ],
          "condition": "http.method in ['GET', 'HEAD']",
          "verdict": "allow"
        }
      },
      "github-writes": {
        "body": {
          "name": "github-writes",
          "family": "http",
          "endpoints": [
            "github"
          ],
          "condition": "http.method in ['POST', 'PATCH', 'DELETE']",
          "approve": [
            {
              "name": "ops"
            }
          ]
        }
      }
    }
  },
  "unknown_host": "passthrough"
}
