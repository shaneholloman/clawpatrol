    "rules": {
      "clickhouse-default": {
        "body": {
          "name": "clickhouse-default",
          "family": "sql",
          "endpoints": [
            "ch-o11y-https",
            "ch-o11y-native"
          ],
          "priority": -100,
          "verdict": "deny",
          "reason": "ClickHouse access is read-only"
        }
      },
      "clickhouse-reads": {
        "body": {
          "name": "clickhouse-reads",
          "family": "sql",
          "endpoints": [
            "ch-o11y-https",
            "ch-o11y-native"
          ],
          "condition": "sql.verb in ['select', 'show', 'describe', 'explain', 'use']",
          "verdict": "allow"
        }
      },
      "deno-deploy-default": {
        "body": {
          "name": "deno-deploy-default",
          "family": "http",
          "endpoints": [
            "deno-deploy"
          ],
          "priority": -100,
          "verdict": "deny",
          "reason": "console.deno.com mutations require an explicit approval rule"
        }
      },
      "deno-deploy-reads": {
        "body": {
          "name": "deno-deploy-reads",
          "family": "http",
          "endpoints": [
            "deno-deploy"
          ],
          "condition": "http.method == 'GET'",
          "verdict": "allow"
        }
      },
      "deno-deploy-reply-on-behalf": {
        "body": {
          "name": "deno-deploy-reply-on-behalf",
